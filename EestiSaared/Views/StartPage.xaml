<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="EestiSaared.Views.StartPage">

    <StackLayout>
        <CarouselView ItemsSource="{Binding ImageItems}" x:Name="carouselView"
                      WidthRequest="300" HeightRequest="200">
            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Image Source="{Binding ImagePath}" Aspect="AspectFit"/>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- Navigation Arrows -->
        <StackLayout Orientation="Horizontal" HorizontalOptions="CenterAndExpand">
            <Button Text="Previous" Clicked="OnPreviousClicked"/>
            <Button Text="Next" Clicked="OnNextClicked"/>
        </StackLayout>
    </StackLayout>  

</ContentPage>
    