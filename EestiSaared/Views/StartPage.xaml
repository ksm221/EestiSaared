<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:EestiSaared.Models;assembly=EestiSaared"
             mc:Ignorable="d"
             x:Class="EestiSaared.Views.StartPage"
             BindingContext="{Binding Source={local:MainViewModel}}">

    <CollectionView ItemsSource="{Binding ImageItems}">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Horizontal" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate>          
                <Image x:Name="TestImage" Source="{Binding ImagePath}" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
